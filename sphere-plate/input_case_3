units si
dimension 3
boundary p p p
atom_style ls/dem
comm_modify vel yes
atom_modify map yes
newton off

region		box block -50 50 -50 50 -50 50 units box
create_box 	1 box

mass 1 1.0

# Set number of nodes
variable N equal 3200

# Loading the nodes
# Test 3: constant shear spin about x and y, no translation.
# The sphere is placed at a constant overlap h = R - d = 1.0 - 0.95 = 0.05 m,
# i.e. centre at z = 0.95 (plate top surface is at z = 0), matching the
# fixed-overlap, prescribed-kinematics assumption of the analytical solution.
read_data	nodes_sphere_${N} add 0 1 shift 0.0 0.0 0.95
read_data	nodes_plate_${N} add ${N} 2 shift 0.0 0.0 -0.5

# Defining the objects as collections of nodes
group		grain1 molecule 1
group		grain2 molecule 2

# No gravity is applied in this test: the sphere is held at a fixed overlap
# with prescribed kinematics, and the analytical contact force/torque carry
# no gravitational term. Applying gravity would only add a constant offset to
# the measured normal force and make the held body accelerate.

# Immobilise bottom object
fix 		immob grain2 freeze

# Disable internal interactions
neigh_modify   exclude molecule/intra all

# Apply LS-DEM fix (no gravity, see note above)
fix			lsfix all rigid/ls/dem molecule infile fixfile_sphere-plate

# Contact model 
pair_style 	ls/dem 1.0
# Contact model parameters and constants
# pair_coeff type type kn kt mu etan etat knp cut kn1 etan1 kt1 etat1
# NOTE: kt = 0.5e8 here to match analytical_solutions.py (kn=1e8, kt=0.5e8,
# mu=0.5, etan=1e6, etat=1e6). The example input_case_1 used kt=0.25e8, which
# is irrelevant to the normal-only bounce but WOULD matter here; reconcile the
# two if needed so the simulation and analytical solution use the same kt.
pair_coeff 	* * 1.0e8 0.5e8 0.5 1.0e6 1.0e6 0 1.0 0 0 0 0

# Neighbour list binning (0.2 times cut from pair_coeff)
neighbor 0.2 bin

# --- Prescribed constant kinematics with infinite inertia -----------------
# Initialise the body translational and angular velocity. With the hold
# fixes below zeroing the net force and torque every step, the body keeps
# these values for the whole run (an 'infinite inertia' body), reproducing
# the constant-velocity / constant-spin assumption of the analytical solution.
set group grain1 vx 0.0 vy 0.0 vz 0.0 omega 5.0 3.0 0.0

# Hold the body and, as a side effect, measure the contact reaction:
#   fix setforce      -> zeroes the net force, holds vcm; its global 3-vector
#                        f_holdforce[1..3] is the total force on the body
#                        BEFORE zeroing, i.e. the contact force (fx,fy,fz).
#   fix settorque/atom -> zeroes the net torque, holds omega; its global
#                        3-vector f_holdtorque[1..3] is the total torque
#                        BEFORE zeroing, i.e. the contact torque (tx,ty,tz).
# In this LS-DEM code the contact lever-arm torque is stored per node in
# atom->torque and summed into the body torque, so zeroing it cleanly holds
# the spin and the reported vector equals the contact torque about the COM.
fix 		holdforce  grain1 setforce 0.0 0.0 0.0
fix 		holdtorque grain1 settorque/atom 0.0 0.0 0.0

thermo_style custom step
timestep 1e-4
thermo 1000

# LAMMPS allow to get the column of a global array with array[col] but not the row, so we must print all values by hand
# x y z vx vy vz fx fy fz tx ty tz
# Position and velocity come from the rigid-body array f_lsfix[1][1..6];
# the contact force and torque come from the hold fixes (see note above),
# because under the hold fixes f_lsfix[1][7..12] would report zero.
fix 	printer all print 10 "$(step) $(f_lsfix[1][1]) $(f_lsfix[1][2]) $(f_lsfix[1][3]) $(f_lsfix[1][4]) $(f_lsfix[1][5]) $(f_lsfix[1][6]) $(f_holdforce[1]) $(f_holdforce[2]) $(f_holdforce[3]) $(f_holdtorque[1]) $(f_holdtorque[2]) $(f_holdtorque[3])" file dump_grain_shear_${N}.txt screen no

#dump mydump grain1 custom 10 dump_grain_shear_${N} id type mol x y z vx vy vz fx fy fz

run 50000

# End of file
